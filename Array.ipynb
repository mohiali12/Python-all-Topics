   "source": [
    "import array \n",
    "\n",
    "arr = array.array('i', [1,2,3,4,5,6])\n",
    "print(arr)\n",
    "\n",
    "for i in range(0,6):\n",
    "    print(arr[i], end =' ')\n",
    "\n",
    "\n",
    "for i in arr:\n",
    "    print(i, end = '\\n')"
   ]
